#!/bin/bash
# Clear Laravel caches for an app path.
# Usage: gzb-laravel-refresh /path/to/laravel

set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -f "$SCRIPT_DIR/../lib/common.sh" ]]; then
  # shellcheck source=../lib/common.sh
  source "$SCRIPT_DIR/../lib/common.sh"
elif [[ -f /usr/local/lib/vps-automation/common.sh ]]; then
  # shellcheck source=/dev/null
  source /usr/local/lib/vps-automation/common.sh
else
  source /home/root1/vps-automation/lib/common.sh
fi

[[ $# -eq 1 ]] || gzb_die "usage: gzb-laravel-refresh <app-path>"

gzb_laravel_refresh "$1"
