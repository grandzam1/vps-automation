#!/bin/bash
# Install Grandzam VPS automation scripts to /usr/local/bin
# Usage: sudo gzb-install

set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

if [[ "${EUID:-$(id -u)}" -ne 0 ]]; then
  echo "Please run as root: sudo $ROOT/bin/gzb-install" >&2
  exit 1
fi

install -d /usr/local/lib/vps-automation
install -m 0644 "$ROOT/lib/common.sh" /usr/local/lib/vps-automation/common.sh
install -m 0644 "$ROOT/projects.conf" /usr/local/lib/vps-automation/projects.conf
echo "installed /usr/local/lib/vps-automation/common.sh"
echo "installed /usr/local/lib/vps-automation/projects.conf"

for script in gzb-sync gzb-laravel-refresh gzb-apps gzb-install; do
  install -m 0755 "$ROOT/bin/$script" "/usr/local/bin/$script"
  echo "installed /usr/local/bin/$script"
done

echo "VPS automation scripts installed."
