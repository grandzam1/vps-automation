#!/bin/bash
# Show git status for all registered VPS projects.
# Usage: gzb-apps

set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -f "$SCRIPT_DIR/../lib/common.sh" ]]; then
  # shellcheck source=../lib/common.sh
  source "$SCRIPT_DIR/../lib/common.sh"
elif [[ -f /usr/local/lib/vps-automation/common.sh ]]; then
  # shellcheck source=/dev/null
  source /usr/local/lib/vps-automation/common.sh
else
  source /home/root1/vps-automation/lib/common.sh
fi

MANIFEST="${GZB_APPS_MANIFEST}"

[[ -f "$MANIFEST" ]] || gzb_die "manifest not found: $MANIFEST"

printf "%-28s %-55s %s\n" "NAME" "PATH" "GIT STATUS"
printf "%-28s %-55s %s\n" "----" "----" "----------"

while IFS='|' read -r name path repo _; do
  [[ -z "$name" || "$name" =~ ^# ]] && continue
  name="$(echo "$name" | xargs)"
  path="$(echo "$path" | xargs)"
  repo="$(echo "$repo" | xargs)"

  if [[ ! -d "$path" ]]; then
    printf "%-28s %-55s %s\n" "$name" "$path" "MISSING"
    continue
  fi

  status="$(gzb_git_status_short "$path")"
  printf "%-28s %-55s %s\n" "$name" "$path" "$status"
  [[ -n "$repo" ]] && echo "  repo: $repo"
done < "$MANIFEST"
